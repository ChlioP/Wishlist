# Keep the local mock repositories active until Firebase adapters are ready.
VITE_DATA_PROVIDER=local

# Firebase web application configuration.
# These values are public client configuration, not server secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Reserved for the Firebase Emulator integration phase.
VITE_USE_FIREBASE_EMULATORS=false
