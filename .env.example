# Use "local" for seeded browser-local data or "firebase" for Firebase adapters.
VITE_DATA_PROVIDER=local

# Firebase web application configuration.
# Required when VITE_DATA_PROVIDER=firebase.
# These values are public client configuration, not server secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Connect Auth, Firestore, and Storage to the ports configured in firebase.json.
VITE_USE_FIREBASE_EMULATORS=false
